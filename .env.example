# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-api-key-here

# Model for per-pattern analysis (-i flag)
# Recommended: inception/mercury-2  (insanely fast & cheap)
OPENROUTER_MODEL=inception/mercury-2

# Model for deep context analysis (-d flag) — use a stronger model here
# Recommended: minimax/minimax-m2.7
OPENROUTER_MODEL_DEEP=minimax/minimax-m2.7

# ── Paths ─────────────────────────────────────────────────────────────────────
# Directory containing Conpot log files (.json and .json.gz)
# Windows example: C:\Programmieren\logs_honeypot\conpot\log
# Linux example:   /var/log/conpot
LOG_DIR=

# ── Language ──────────────────────────────────────────────────────────────────
# Language for UI output and LLM prompts
# Available: de (Deutsch), en (English)
LANG=en
